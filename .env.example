# ── Authentication ────────────────────────────────────────────────────
#
# Pick ONE auth method. The SDK auto-detects which you've configured.
#
# Option A: Google AI (API key) — fastest to get started.
#   Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
# Option B: Vertex AI — enterprise, IAM-based.
#   Requires `gcloud auth print-access-token` or GOOGLE_ACCESS_TOKEN.
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=my-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
#
# Option C: Explicit access token (either platform).
#   Useful in CI or when you manage token refresh yourself.
# GOOGLE_ACCESS_TOKEN=ya29.xxx

# ── Live Session Model ───────────────────────────────────────────────
#
# Override the default Live (WebSocket) model. Omit to use the SDK
# default (models/gemini-live-2.5-flash-native-audio).
#
# Always include the `models/` prefix — both platforms accept it:
#   Google AI  → sent as-is in the setup message
#   Vertex AI  → SDK strips `models/` and builds the resource path:
#                projects/{project}/locations/{loc}/publishers/google/models/...
#
# GEMINI_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025

# ── Text LLM (extractors, agent tools) ──────────────────────────────
#
# Advanced examples (tool-calling, playbook, clinic, etc.) use a
# secondary text LLM for turn extraction, agent-as-tool pipelines,
# and background analysis. This is a REST-based `GeminiLlm`, separate
# from the Live WebSocket session above.
#
# The text LLM model and location are set per-app in code via
# GeminiLlmParams — NOT from env vars:
#
#   let llm = GeminiLlm::new(GeminiLlmParams {
#       model: Some("gemini-3.1-flash-lite-preview".into()),
#       ..Default::default()  // inherits auth from env
#   });
#
# Auth is shared: the text LLM reads the SAME auth env vars above
# (GEMINI_API_KEY for Google AI, or GOOGLE_CLOUD_PROJECT + token for
# Vertex AI). No extra env vars needed.
#
# Google AI:  Just works — single API key covers both Live + text LLM.
#
# Vertex AI:  The text LLM may need a DIFFERENT location than the Live
#             session. The native audio model is region-locked to
#             us-central1, but gemini-3.1-flash-lite-preview is available
#             at the `global` endpoint. Examples handle this by setting
#             `location: Some("global".into())` in GeminiLlmParams.

# ── Telemetry (optional) ─────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=https://telemetry.googleapis.com
# OTEL_SERVICE_NAME=gemini-rs
